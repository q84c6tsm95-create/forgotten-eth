{
  "ignoreCommand": "sh .vercel-ignore.sh",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api-docs.html"
    },
    {
      "source": "/changelog",
      "destination": "/changelog.html"
    },
    {
      "source": "/feed.xml",
      "destination": "/api/feed"
    },
    {
      "source": "/protocol/:slug",
      "destination": "/:slug"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    }
  ],
  "functions": {
    "api/check.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "{data/index_shards/**/*.json,data/eligible_checkers/recognition.json}"
    },
    "api/check-batch.js": {
      "memory": 512,
      "maxDuration": 15,
      "includeFiles": "data/index_shards/**/*.json"
    },
    "api/health.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "{data/health.json,data/total.json,data/index_shards/meta.json,data/index_shards/13.json,data/index_shards/61.json,data/index_shards/1d.json,data/index_shards/e1.json}"
    },
    "api/table.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "{data/table_meta/**/*.json,data/tvl/**/*.json,data/protocols.json}"
    },
    "api/summary.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "data/table_meta/**/*.json"
    },
    "api/total.js": {
      "memory": 128,
      "maxDuration": 5,
      "includeFiles": "data/total.json"
    },
    "api/stats.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/claims.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/eligible-recognition-seen.js": {
      "memory": 128,
      "maxDuration": 5
    },
    "api/protocol.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "{data/table_meta/**/*.json,data/tvl/**/*.json,data/protocol_info.json}"
    },
    "api/sitemap.js": {
      "memory": 128,
      "maxDuration": 5,
      "includeFiles": "data/protocol_info.json"
    },
    "api/feed.js": {
      "memory": 128,
      "maxDuration": 5,
      "includeFiles": "public/changelog.html"
    },
    "api/dune-webhook.js": {
      "maxDuration": 15,
      "includeFiles": "{data/protocols.json,data/withdrawal_events.json}"
    },
    "api/quick-scan.js": {
      "includeFiles": "{data/protocols.json,data/balances/**/*.json}"
    }
  },
  "headers": [
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=60, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'none'; script-src 'self' https://cdn.jsdelivr.net/npm/ethers@6.13.5/dist/ethers.umd.min.js https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' https://ethereum.publicnode.com https://1rpc.io https://eth.llamarpc.com https://vitals.vercel-insights.com https://api.coingecko.com https://cdn.jsdelivr.net; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; frame-ancestors 'none';"
        }
      ]
    },
    {
      "source": "/protocol/:slug",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'none'; script-src 'self' https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self'; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; frame-ancestors 'none';"
        }
      ]
    },
    {
      "source": "/api/(check|check-batch|summary|table|total|stats|claims|sitemap|feed)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=120"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "max-age=60"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
