{
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- public/ api/ vercel.json package.json data/index_shards/ data/table_meta/ data/tvl/ data/protocol_info.json data/protocols.json",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api-docs.html"
    },
    {
      "source": "/changelog",
      "destination": "/changelog.html"
    },
    {
      "source": "/protocol/:slug",
      "destination": "/:slug"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    }
  ],
  "functions": {
    "api/check.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "data/index_shards/**/*.json"
    },
    "api/check-batch.js": {
      "memory": 512,
      "maxDuration": 15,
      "includeFiles": "data/index_shards/**/*.json"
    },
    "api/health.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "{data/health.json,data/total.json}"
    },
    "api/table.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "{data/table_meta/**/*.json,data/tvl/**/*.json,data/protocols.json}"
    },
    "api/summary.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "data/table_meta/**/*.json"
    },
    "api/total.js": {
      "memory": 128,
      "maxDuration": 5,
      "includeFiles": "data/total.json"
    },
    "api/stats.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/claims.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/protocol.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "{data/table_meta/**/*.json,data/tvl/**/*.json,data/protocol_info.json}"
    },
    "api/sitemap.js": {
      "memory": 128,
      "maxDuration": 5,
      "includeFiles": "data/protocol_info.json"
    },
    "api/dune-webhook.js": {
      "includeFiles": "data/protocols.json"
    },
    "api/quick-scan.js": {
      "includeFiles": "{data/protocols.json,data/balances/**/*.json}"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'none'; script-src 'self' https://cdn.jsdelivr.net/npm/ethers@6.13.5/dist/ethers.umd.min.js https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' https://ethereum.publicnode.com https://1rpc.io https://eth.llamarpc.com https://vitals.vercel-insights.com https://api.coingecko.com https://cdn.jsdelivr.net; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; frame-ancestors 'none';"
        }
      ]
    },
    {
      "source": "/protocol/:slug",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'none'; script-src 'self' https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self'; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; frame-ancestors 'none';"
        }
      ]
    },
    {
      "source": "/api/(check|check-batch|summary|table|total|stats|claims|sitemap)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=60, stale-while-revalidate=120"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
